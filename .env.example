# ──────────────────────────────────────────────
#  PLAID
#  → Crée un compte sur dashboard.plaid.com
#  → Copie Client ID + Secret (Production ou Sandbox)
#  → Lance `python setup_plaid.py` pour obtenir ACCESS_TOKEN
# ──────────────────────────────────────────────
PLAID_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
PLAID_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PLAID_ACCESS_TOKEN=access-production-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PLAID_ENV=production

# ──────────────────────────────────────────────
#  WISE
#  → wise.com → Settings → API tokens → "Read-only"
#  → Profile ID: wise.com/settings/account (URL ou API /v1/profiles)
# ──────────────────────────────────────────────
WISE_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WISE_PROFILE_ID=12345678

# ──────────────────────────────────────────────
#  PHANTOM (Solana) — adresse publique seulement
#  → Phantom wallet → copy public key
# ──────────────────────────────────────────────
PHANTOM_WALLET=YourSolanaPublicKeyHere

# ──────────────────────────────────────────────
#  OPTIONS
# ──────────────────────────────────────────────
USD_TO_CAD=1.38
# Date de début pour les transactions (YYYY-MM-DD)
START_DATE=2025-01-01
