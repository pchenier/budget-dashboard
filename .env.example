# ── Plaid (obligatoire) ──────────────────────────────────────────
# Créer un compte sur https://dashboard.plaid.com
# Team Settings → Keys pour le Client ID et Secret
# Utiliser setup_plaid.py pour obtenir ton Access Token

PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ACCESS_TOKEN=access-production-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PLAID_ENV=production

# ── Wise (optionnel) ─────────────────────────────────────────────
# https://wise.com/settings/account → API tokens → Read-only

WISE_TOKEN=your_wise_api_token
WISE_PROFILE_ID=your_wise_profile_id

# ── Solana / Phantom (optionnel) ─────────────────────────────────
# Adresse publique seulement (read-only)

PHANTOM_WALLET=YourSolanaPublicKeyHere

# ── Options ──────────────────────────────────────────────────────

USD_TO_CAD=1.38
START_DATE=2025-01-01

# ── Flask ────────────────────────────────────────────────────────
# Générer avec: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change_me_to_a_random_secret
